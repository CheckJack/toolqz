# =============================================================================
# Hostinger Business — Managed Node.js (recommended for your plan)
# =============================================================================
# hPanel → Websites → Add Website → Node.js Apps → Import Git Repository
# Repo: https://github.com/CheckJack/toolqz
#
# Build settings:
#   Install:  npm ci
#   Build:    npm run build
#   Start:    npm run start
#   Node.js:  20.x
#
# Database: hPanel → Database Connect Wizard → Supabase (sets DATABASE_URL)
# Env vars: copy deploy/hostinger-managed.env.example
#
# After first successful deploy, seed production DB once (from your Mac):
#   DATABASE_URL="your-supabase-url" npm run db:seed
#
# =============================================================================
# Local dev (SQLite)
# =============================================================================
DATABASE_URL="file:./dev.db"

# Auth — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-secret-at-least-32-chars"

# Public site URL (no trailing slash) — your Hostinger domain
NEXT_PUBLIC_APP_URL="https://yourdomain.com"

# Admin seed credentials (first deploy only: npm run db:seed)
ADMIN_EMAIL="admin@toolqz.com"
ADMIN_PASSWORD="changeme"

# Cron — required on Hostinger (see deploy/crontab.example)
CRON_SECRET=""

# Docker production compose only (deploy/docker-compose.prod.yml)
POSTGRES_PASSWORD="change-me-strong-password"

# Email (Brevo) — https://app.brevo.com → SMTP & API
# Use xkeysib-... for REST API, or xsmtpsib-... with BREVO_SMTP_USER for SMTP relay
BREVO_API_KEY=""
BREVO_SMTP_USER="tc@toolqz.com"
NOTIFY_FROM_EMAIL="TOOLQZ <noreply@toolqz.com>"
PARTNER_INQUIRY_EMAIL="tc@toolqz.com"

# Google AdSense — optional
NEXT_PUBLIC_ADSENSE_CLIENT_ID=""
NEXT_PUBLIC_ADSENSE_SLOT=""

# Google Analytics 4 — optional (https://analytics.google.com)
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-FGS86Q3BC0"

# Hostinger API — local CLI + Cursor MCP (https://hpanel.hostinger.com/profile/api)
HOSTINGER_API_TOKEN=""
HOSTINGER_DOMAIN="toolqz.com"

# GA4 Data API (admin site-traffic dashboard — server only, never expose to client)
GA4_PROPERTY_ID=""
# Recommended on Hostinger — run: npm run ga4:env -- path/to/service-account.json
GA4_CREDENTIALS_BASE64=""
# Or: GA4_CREDENTIALS_JSON='{"type":"service_account",...}'
# Avoid GA4_PRIVATE_KEY on Hostinger — multi-line PEM often breaks.
