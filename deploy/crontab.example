# TOOLQZ cron jobs (Hostinger — schedule via hPanel Cron Jobs or VPS crontab).
# Replace YOUR_DOMAIN and YOUR_CRON_SECRET.
#
# Analytics snapshot — daily at 6:00 UTC
# 0 6 * * * curl -fsS -H "Authorization: Bearer YOUR_CRON_SECRET" https://YOUR_DOMAIN/api/cron/analytics-snapshot >/dev/null 2>&1
#
# 0 8 * * * curl -fsS -H "Authorization: Bearer YOUR_CRON_SECRET" https://YOUR_DOMAIN/api/cron/follow-ups >/dev/null 2>&1
#
# Daily task digest — 9:00 Europe/Lisbon (Portugal)
# CRON_TZ=Europe/Lisbon
# 0 9 * * * curl -fsS -H "Authorization: Bearer YOUR_CRON_SECRET" https://YOUR_DOMAIN/api/cron/daily-tasks >/dev/null 2>&1
#
# Build status monitor — every 5 minutes (deploy started / completed / failed)
# */5 * * * * curl -fsS -H "Authorization: Bearer YOUR_CRON_SECRET" https://YOUR_DOMAIN/api/cron/build-monitor >/dev/null 2>&1
#
# Uptime / site health — every 10 minutes (alerts when site goes down or recovers)
# */10 * * * * curl -fsS -H "Authorization: Bearer YOUR_CRON_SECRET" https://YOUR_DOMAIN/api/cron/uptime-check >/dev/null 2>&1
