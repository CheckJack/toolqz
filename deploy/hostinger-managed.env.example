# Hostinger → Node.js app → Environment Variables
# Domain: https://whitesmoke-coyote-728786.hostingersite.com

NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://whitesmoke-coyote-728786.hostingersite.com

# openssl rand -base64 32
AUTH_SECRET=
ADMIN_EMAIL=admin@toolqz.com
ADMIN_PASSWORD=changeme

# ── Supabase (from supabase.com → Project → Connect) ─────────────────────────
# Use the URI from "Session pooler" or "Direct connection" (port 5432).
# Do NOT leave placeholders like postgres.xxxxx — use your real project ref.
#
# DATABASE_URL (runtime — Session pooler, port 5432):
# postgresql://postgres.abcdefghijklmnop:YOUR_PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres
#
# DIRECT_URL (migrations — Direct connection, port 5432):
# postgresql://postgres.abcdefghijklmnop:YOUR_PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres
# OR:
# postgresql://postgres:YOUR_PASSWORD@db.abcdefghijklmnop.supabase.co:5432/postgres
#
# Hostinger wizard may set SUPABASE_* keys — you still need a valid DATABASE_URL above.

DATABASE_URL=
DIRECT_URL=

# Set by Hostinger Supabase wizard (optional if DATABASE_URL is correct)
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

CRON_SECRET=
BREVO_API_KEY=
BREVO_SMTP_USER=tc@toolqz.com
NOTIFY_FROM_EMAIL=TOOLQZ <noreply@toolqz.com>
PARTNER_INQUIRY_EMAIL=tc@toolqz.com
NEXT_PUBLIC_ADSENSE_CLIENT_ID=
NEXT_PUBLIC_ADSENSE_SLOT=
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-FGS86Q3BC0

# GA4 Data API — admin site-traffic dashboard (server only)
GA4_PROPERTY_ID=544145954
# Recommended on Hostinger — base64-encoded service account JSON (most reliable):
#   npm run ga4:env -- path/to/service-account.json
# GA4_CREDENTIALS_BASE64=
# GA4_PROPERTY_ID=544145954
# Remove GA4_PRIVATE_KEY / GA4_CLIENT_EMAIL if set — they often break on Hostinger.

# Hostinger API — admin Hosting page (server only)
HOSTINGER_API_TOKEN=
HOSTINGER_DOMAIN=toolqz.com

# Admin AI agent (Gemini — server only)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
AGENT_ENABLED=true

# GA4 Data API — admin site-traffic dashboard (server only)
