# Hostinger Business — Managed Node.js Web App
# Domain: https://whitesmoke-coyote-728786.hostingersite.com
# Set these in hPanel → Websites → your Node.js app → Environment Variables

NODE_ENV=production

# Database — pick ONE option in Hostinger hPanel:

# Option A (recommended): Supabase via Database Connect Wizard (auto-fills DATABASE_URL)
# If manual, use the "Transaction pooler" URI and add sslmode=require:
# DATABASE_URL=postgresql://postgres.xxxx:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require

# Option B: Hostinger MySQL (hPanel → Databases → MySQL → connect wizard)
# DATABASE_URL=mysql://USER:PASSWORD@localhost:3306/DATABASE

DATABASE_URL=

NEXT_PUBLIC_APP_URL=https://whitesmoke-coyote-728786.hostingersite.com

# openssl rand -base64 32
AUTH_SECRET=

# First deploy only — then run seed via Hostinger SSH/file manager if available, or locally against prod DB
ADMIN_EMAIL=admin@toolqz.com
ADMIN_PASSWORD=changeme

# Optional: external cron hitting /api/cron/follow-ups (Hostinger managed has no Vercel cron)
CRON_SECRET=

RESEND_API_KEY=
NOTIFY_FROM_EMAIL=TOOLQZ <onboarding@resend.dev>
PARTNER_INQUIRY_EMAIL=

NEXT_PUBLIC_ADSENSE_CLIENT_ID=
NEXT_PUBLIC_ADSENSE_SLOT=
