{
  "name": "toolqz",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "prisma generate && next dev",
    "dev:clean": "rm -rf .next && prisma generate && next dev",
    "prebuild": "node scripts/sync-prisma-provider.mjs && rm -rf .next",
    "build": "prisma generate && next build",
    "start": "node scripts/production-start.mjs",
    "start:next": "next start -H 0.0.0.0 -p ${PORT:-3000}",
    "lint": "eslint",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:prod": "node scripts/migrate-production.mjs",
    "db:migrate:resolve": "node scripts/migrate-resolve-production.mjs",
    "db:migrate:dev": "prisma migrate dev",
    "db:local": "node scripts/sync-prisma-provider.mjs && prisma db push",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:setup": "prisma migrate deploy && tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "hostinger": "node scripts/hostinger.mjs",
    "hostinger:websites": "node scripts/hostinger.mjs websites",
    "hostinger:builds": "node scripts/hostinger.mjs builds",
    "hostinger:logs": "node scripts/hostinger.mjs logs",
    "hostinger:setup-mcp": "node scripts/hostinger.mjs setup-mcp",
    "ga4:env": "node scripts/ga4-env-oneline.mjs",
    "test": "node --import tsx --test src/lib/agent/__tests__/*.test.ts",
    "postinstall": "node scripts/sync-prisma-provider.mjs && prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@google-analytics/data": "^6.1.0",
    "@prisma/client": "^5.22.0",
    "@tailwindcss/postcss": "^4.1.10",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.15.32",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "eslint": "^9.29.0",
    "eslint-config-next": "^15.3.4",
    "hls.js": "^1.6.16",
    "jose": "^6.2.3",
    "lucide-react": "^1.23.0",
    "next": "^15.3.4",
    "prisma": "^5.22.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "recharts": "^3.9.2",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.1.10",
    "typescript": "^5.8.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "tsx": "^4.22.4"
  },
  "overrides": {
    "postcss": "^8.5.16"
  }
}
