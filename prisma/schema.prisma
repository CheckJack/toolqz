generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url       = env("DATABASE_URL")
}

model User {
  id           String              @id @default(cuid())
  email        String              @unique
  name         String
  passwordHash String
  role         String              @default("MEMBER")
  lastLoginAt  DateTime?
  emailFollowUpReminders Boolean     @default(true)
  emailBuildAlerts       Boolean     @default(true)
  emailTaskDigest        Boolean     @default(true)
  emailMessageAlerts     Boolean     @default(true)
  createdAt    DateTime            @default(now())
  affiliates   AffiliateProgram[]
  activities   AffiliateActivity[]
  auditLogs    AdminAuditLog[]
  notifications AdminNotification[]
  teamConversationsA TeamConversation[] @relation("TeamConvA")
  teamConversationsB TeamConversation[] @relation("TeamConvB")
  teamMessages       TeamMessage[]
  teamConversationReads TeamConversationRead[]
  financeEntries     FinanceEntry[]
  blogPosts          BlogPost[]
  chatSessions       AdminChatSession[]
  passwordResetTokens PasswordResetToken[]
  assignedTasks      AdminTask[]          @relation("AssignedTasks")
  createdTasks         AdminTask[]          @relation("CreatedTasks")
  playbookSnippets   AdminPlaybookSnippet[]
  notes              AdminNote[]
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Tool {
  id           String            @id @default(cuid())
  slug         String            @unique
  name         String
  description  String
  overview     String
  highlights   String
  url          String
  affiliateUrl String?
  listingType  String            @default("EDITORIAL")
  category     String
  tags         String
  featured     Boolean           @default(false)
  rating       Float?
  published    Boolean           @default(true)
  logoUrl      String?
  screenshots  String            @default("[]")
  whoIsItFor   String            @default("")
  notForYouIf  String?
  howItWorks   String            @default("[]")
  pricing      String            @default("[]")
  pros         String            @default("[]")
  cons         String            @default("[]")
  faq          String            @default("[]")
  lastReviewed String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  clicks       Click[]
  affiliate    AffiliateProgram?
  slugRedirects ToolSlugRedirect[]
}

model ToolCategory {
  id          String   @id @default(cuid())
  slug        String   @unique
  label       String
  description String?
  sortOrder   Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([published, sortOrder])
}

model ToolSlugRedirect {
  id        String   @id @default(cuid())
  oldSlug   String   @unique
  toolId    String
  tool      Tool     @relation(fields: [toolId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([toolId])
}

model Click {
  id                 String            @id @default(cuid())
  toolId             String
  tool               Tool              @relation(fields: [toolId], references: [id], onDelete: Cascade)
  referrer           String?
  userAgent          String?
  clickedAt          DateTime          @default(now())
  utmSource          String?
  utmMedium          String?
  utmCampaign        String?
  utmContent         String?
  utmTerm            String?
  sourcePage         String?
  listingType        String?
  affiliateProgramId String?
  affiliateProgram   AffiliateProgram? @relation(fields: [affiliateProgramId], references: [id], onDelete: SetNull)
  isBot              Boolean           @default(false)
  ipHash             String?

  @@index([toolId])
  @@index([clickedAt])
  @@index([isBot])
  @@index([utmSource])
  @@index([affiliateProgramId])
}

model AffiliateProgram {
  id               String              @id @default(cuid())
  companyName      String
  website          String?
  signupUrl        String?
  portalUrl        String?
  status           String              @default("PENDING")
  priority         String              @default("MEDIUM")
  category         String?
  commission       String?
  isRecurring      Boolean?
  cookieDuration   String?
  affiliateNetwork String?
  affiliateUrl     String?
  commissionNotes  String?
  notes            String?
  contactEmail     String?
  rejectionReason  String?
  applicationId    String?
  source           String?             @default("manual")
  contactedAt      DateTime?
  nextFollowUpAt   DateTime?
  followUpNotifiedAt DateTime?
  appliedAt        DateTime?
  approvedAt       DateTime?
  toolId           String?             @unique
  tool             Tool?               @relation(fields: [toolId], references: [id], onDelete: SetNull)
  assignedToId     String?
  assignedTo       User?               @relation(fields: [assignedToId], references: [id], onDelete: SetNull)
  activities       AffiliateActivity[]
  financeEntries   FinanceEntry[]
  adminTasks         AdminTask[]
  clicks             Click[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([status])
  @@index([assignedToId])
  @@index([category])
  @@index([nextFollowUpAt])
}

model AffiliateActivity {
  id          String           @id @default(cuid())
  affiliateId String
  affiliate   AffiliateProgram @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  type        String
  content     String
  createdAt   DateTime         @default(now())

  @@index([affiliateId])
}

model AdminAuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  entity    String
  entityId  String?
  detail    String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([entity])
}

model AdminNotification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String?
  href      String?
  entityId  String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
  @@index([createdAt])
  @@index([entityId, type])
}

model TeamConversation {
  id        String   @id @default(cuid())
  userAId   String
  userBId   String
  userA     User     @relation("TeamConvA", fields: [userAId], references: [id], onDelete: Cascade)
  userB     User     @relation("TeamConvB", fields: [userBId], references: [id], onDelete: Cascade)
  messages  TeamMessage[]
  reads     TeamConversationRead[]
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
  @@index([updatedAt])
}

model TeamMessage {
  id             String           @id @default(cuid())
  conversationId String
  conversation   TeamConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User             @relation(fields: [senderId], references: [id], onDelete: Cascade)
  body           String
  createdAt      DateTime         @default(now())

  @@index([conversationId, createdAt])
}

model TeamConversationRead {
  conversationId String
  userId         String
  lastReadAt     DateTime         @default(now())
  conversation   TeamConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
}

model FinanceEntry {
  id                 String            @id @default(cuid())
  type               String
  amount             Float
  currency           String            @default("EUR")
  description        String
  source             String?
  affiliateProgramId String?
  affiliateProgram   AffiliateProgram? @relation(fields: [affiliateProgramId], references: [id], onDelete: SetNull)
  occurredAt         DateTime
  notes              String?
  createdById        String?
  createdBy          User?             @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([type])
  @@index([occurredAt])
}

model PartnerInquiry {
  id          String   @id @default(cuid())
  companyName String
  contactName String
  email       String
  website     String?
  productType String
  message     String
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([email])
}

model NewsletterSubscriber {
  id              String    @id @default(cuid())
  email           String    @unique
  name            String?
  status          String    @default("ACTIVE")
  source          String    @default("popup")
  subscribedAt    DateTime  @default(now())
  unsubscribedAt  DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status])
  @@index([subscribedAt])
  @@index([email])
}

model BlogPost {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  excerpt     String
  content     String
  coverImage  String?
  published   Boolean   @default(false)
  publishedAt DateTime?
  authorId    String?
  author      User?     @relation(fields: [authorId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([published, publishedAt])
  @@index([createdAt])
}

model AdminChatSession {
  id        String             @id @default(cuid())
  userId    String
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  messages  AdminChatMessage[]

  @@index([userId, updatedAt])
}

model AdminChatMessage {
  id        String           @id @default(cuid())
  sessionId String
  session   AdminChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String
  content   String
  metadata  String?
  createdAt DateTime         @default(now())

  @@index([sessionId, createdAt])
}

model AdminTask {
  id           String    @id @default(cuid())
  title        String
  description  String?
  section      String    @default("general")
  status       String    @default("TODO")
  priority     String    @default("MEDIUM")
  dueAt        DateTime?
  sortOrder    Int       @default(0)
  linkUrl            String?
  linkLabel          String?
  affiliateProgramId String?
  affiliateProgram   AffiliateProgram? @relation(fields: [affiliateProgramId], references: [id], onDelete: SetNull)
  assignedToId       String?
  assignedTo   User?     @relation("AssignedTasks", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdById  String?
  createdBy    User?     @relation("CreatedTasks", fields: [createdById], references: [id], onDelete: SetNull)
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([section, status, sortOrder])
  @@index([assignedToId])
  @@index([dueAt])
  @@index([status])
  @@index([affiliateProgramId])
}

model AdminPlaybookSnippet {
  id          String   @id @default(cuid())
  question    String
  answer      String
  category    String   @default("other")
  aliases     String?
  tags        String?
  pinned      Boolean  @default(false)
  sensitive   Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([pinned])
  @@index([sensitive])
  @@index([sortOrder])
}

model SystemMonitorState {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model AnalyticsSnapshot {
  id        String   @id @default(cuid())
  date      String   @unique
  payload   String
  createdAt DateTime @default(now())

  @@index([date])
}

model AffiliateConversion {
  id        String   @id @default(cuid())
  date      DateTime
  toolSlug  String?
  amount    Float
  currency  String   @default("USD")
  network   String?
  notes     String?
  createdAt DateTime @default(now())

  @@index([date])
  @@index([toolSlug])
}

model AdminNote {
  id          String                @id @default(cuid())
  title       String
  content     String                @default("")
  visibility  String                @default("PRIVATE")
  pinned      Boolean               @default(false)
  createdById String
  createdBy   User                  @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  links       AdminNoteLink[]
  attachments AdminNoteAttachment[]

  @@index([createdById])
  @@index([visibility])
  @@index([updatedAt])
  @@index([pinned])
}

model AdminNoteLink {
  id        String    @id @default(cuid())
  noteId    String
  note      AdminNote @relation(fields: [noteId], references: [id], onDelete: Cascade)
  label     String
  url       String
  createdAt DateTime  @default(now())

  @@index([noteId])
}

model AdminNoteAttachment {
  id          String    @id @default(cuid())
  noteId      String
  note        AdminNote @relation(fields: [noteId], references: [id], onDelete: Cascade)
  fileName    String
  mimeType    String
  sizeBytes   Int
  storagePath String
  createdAt   DateTime  @default(now())

  @@index([noteId])
}
