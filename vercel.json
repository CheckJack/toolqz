{
  "buildCommand": "prisma generate && prisma migrate deploy && next build",
  "crons": [
    {
      "path": "/api/cron/follow-ups",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/daily-tasks",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/build-monitor",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/uptime-check",
      "schedule": "*/10 * * * *"
    }
  ]
}
